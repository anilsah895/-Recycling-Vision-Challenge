ype":"code","source":"print(\"Float complete model in Mb:\", os.stat('./best2_model.h5').st_size/ float(2**20))\nprint(\"lite model in Mb:\", os.stat('./tflite_models/model.tflite').st_size/ float(2**20))\nprint(\"quant lite model in Mb:\", os.stat('./tflite_models/model_quant.tflite').st_size/ float(2**20))\n#print(\"QAT compressed model in Mb:\", os.stat('vgg_qat_full_model.tflite').st_size/ float(2**20))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Resize input and output tensors shapes\n\nLet's resize input and output tensors, so we can make predictions for batch of 25 images.","metadata":{}},{"cell_type":"code","source":"# Load TFLite model and see some details about input/output\n\ntflite_interpreter = tf.lite.Interpreter(model_path=TFLITE_MODEL)\n\ntflite_interpreter.resize_tensor_input(input_details[0]['index'], (25, 256, 256, 3))\ntflite_interpreter.resize_tensor_input(output_details[0]['index'], (25, 12))\ntflite_interpreter.allocate_tensors()\n\ninput_ind = tflite_interpreter.get_input_details()[0][\"index\"]\nout_ind   = tflite_interpreter.get_output_details()[0][\"index\"]\ninput_details = tflite_interpreter.get_input_details()\noutput_details = tflite_interpreter.get_output_details()\n\nprint(\"== Input details ==\")\nprint(\"name:\", input_details[0]['name'])\nprint(\"shape:\", input_details[0]['shape'])\nprint(\"type:\", input_details[0]['dtype'])\n\nprint(\"\\n== Output details ==\")\nprint(\"name:\", output_details[0]['name'])\nprint(\"shape:\", output_details[0]['shape'])\nprint(\"type:\", output_details[0]['dtype'])","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"tflite_interpreter.set_tensor(input_details[0]['index'], val_image_batch)\n\ntflite_interpreter.invoke()\n\ntflite_model_predictions = tflite_interpreter.get_tensor(output_details[0]['index'])\nprint(\"Prediction results shape:\", tflite_model_predictions.shape)","metadata":{"truste